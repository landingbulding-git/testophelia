{
  "manifest_version": 3,
  "name": "Cross-Tab Utility",
  "version": "1.0.0",
  "description": "Ophelia — Record and share guided web tutorials with voice narration",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Ophelia"
  },
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "webNavigation",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["gemini-config.js", "agent-prompt.js", "gemini-tutor.js", "overlay.js", "recorder.js", "player.js", "assistant.js", "content.js"],
      "run_at": "document_end"
    }
  ],
  "commands": {
    "toggle-sphere": {
      "suggested_key": {
        "default": "Ctrl+Shift+U",
        "mac": "MacCtrl+Shift+U"
      },
      "description": "Toggle cross-tab sphere"
    },
    "send-firebase": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "MacCtrl+Shift+F"
      },
      "description": "Start / Stop recording a tutorial"
    }
  }
}
